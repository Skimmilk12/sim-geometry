{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simgeometry.com/data/schema/wheelbases.schema.json",
  "title": "Sim Geometry direct-drive wheelbase dataset (v1)",
  "type": "object",
  "required": ["version", "dataset", "license", "method", "records"],
  "properties": {
    "version": { "type": "string", "pattern": "^1\\." },
    "dataset": { "const": "wheelbases" },
    "license": { "type": "string" },
    "method": { "type": "string" },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["brand", "model", "variant", "lifecycle", "productType", "motorType", "torque", "slewRate", "encoder", "rotationDeg", "platforms", "quickRelease", "mounting", "dimensions", "weightKg", "psu", "included", "requiredNotIncluded", "warranty", "priceUSD", "sources", "confidence", "lastVerified", "notes"],
        "properties": {
          "brand": { "type": "string", "minLength": 1 },
          "model": { "type": "string", "minLength": 1 },
          "variant": { "type": ["string", "null"] },
          "lifecycle": { "enum": ["current", "discontinued", "announced"] },
          "productType": { "enum": ["base", "bundle"] },
          "motorType": { "type": ["string", "null"] },
          "torque": {
            "type": "object",
            "required": ["peakNm", "holdingNm", "claimType", "note"],
            "properties": {
              "peakNm": { "type": ["number", "null"] },
              "holdingNm": { "type": ["number", "null"] },
              "claimType": { "enum": ["peak", "constant", "holding", "max", "overshoot-noted", null] },
              "note": { "type": ["string", "null"] }
            }
          },
          "slewRate": { "type": ["string", "null"] },
          "encoder": {
            "type": "object",
            "required": ["tech", "resolution"],
            "properties": {
              "tech": { "type": ["string", "null"] },
              "resolution": { "type": ["string", "null"] }
            }
          },
          "rotationDeg": { "type": ["number", "string", "null"] },
          "platforms": {
            "type": "object",
            "required": ["pc", "ps", "xbox"],
            "properties": {
              "pc": { "type": "boolean" },
              "ps": { "$ref": "#/$defs/consoleSupport" },
              "xbox": { "$ref": "#/$defs/consoleSupport" }
            }
          },
          "quickRelease": { "type": ["string", "null"] },
          "mounting": { "type": ["string", "null"] },
          "dimensions": { "type": ["string", "null"] },
          "weightKg": { "type": ["number", "null"] },
          "psu": { "type": ["string", "null"] },
          "included": { "type": "array", "items": { "type": "string" } },
          "requiredNotIncluded": { "type": "array", "items": { "type": "string" } },
          "warranty": { "type": ["string", "null"] },
          "priceUSD": {
            "type": ["object", "null"],
            "required": ["amount", "source", "retrieved"],
            "properties": {
              "amount": { "type": ["number", "null"] },
              "source": { "type": ["string", "null"] },
              "retrieved": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
              "note": { "type": ["string", "null"] }
            }
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["url", "kind", "retrieved"],
              "properties": {
                "url": { "type": "string", "pattern": "^https://" },
                "kind": { "type": "string", "minLength": 1 },
                "retrieved": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
                "covers": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "confidence": { "enum": ["high", "medium", "low"] },
          "lastVerified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "consoleSupport": {
      "type": "object",
      "required": ["supported", "condition"],
      "properties": {
        "supported": { "type": ["boolean", "null"] },
        "condition": { "type": ["string", "null"] }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simgeometry.com/data/schema/game-fov-conventions.schema.json",
  "title": "Sim Geometry game FOV conventions dataset (v1)",
  "type": "object",
  "required": ["version", "dataset", "license", "method", "records"],
  "properties": {
    "version": { "type": "string", "pattern": "^1\\." },
    "dataset": { "const": "game-fov-conventions" },
    "license": { "type": "string" },
    "method": { "type": "string" },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["game", "status", "settingName", "convention", "units", "range", "step", "menuPath", "configFile", "configKey", "tripleMode", "tripleNotes", "calculatorMapping", "sources", "confidence", "lastVerified", "notes"],
        "properties": {
          "game": { "type": "string", "minLength": 1 },
          "status": { "enum": ["convertible", "no-conversion"] },
          "settingName": { "type": ["string", "null"] },
          "convention": {
            "type": "object",
            "required": ["axis", "basis", "note"],
            "properties": {
              "axis": { "enum": ["horizontal", "vertical", null] },
              "basis": { "type": ["string", "null"] },
              "note": { "type": "string", "minLength": 1 }
            }
          },
          "units": { "type": ["string", "null"] },
          "range": {
            "type": ["object", "null"],
            "required": ["min", "max"],
            "properties": {
              "min": { "type": "number" },
              "max": { "type": "number" },
              "conditions": { "type": ["string", "null"] }
            }
          },
          "step": { "type": ["number", "null"] },
          "menuPath": { "type": ["string", "null"] },
          "configFile": { "type": ["string", "null"] },
          "configKey": { "type": ["string", "null"] },
          "tripleMode": { "enum": ["native-multi-projection", "experimental-native-multi-projection", "single-span", "unsupported", null] },
          "tripleNotes": { "type": ["string", "null"] },
          "calculatorMapping": {
            "type": "object",
            "required": ["single", "triple"],
            "properties": {
              "single": { "enum": ["horizontalSpan", "verticalSpan", "centerSpan", "visibleEnvelope", "physical-geometry", null] },
              "triple": { "enum": ["horizontalSpan", "verticalSpan", "centerSpan", "visibleEnvelope", "physical-geometry", null] }
            },
            "additionalProperties": false
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["url", "kind", "retrieved"],
              "properties": {
                "url": { "type": "string", "pattern": "^https://" },
                "kind": { "type": "string", "minLength": 1 },
                "retrieved": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
              }
            }
          },
          "confidence": { "enum": ["high", "medium", "low"] },
          "lastVerified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "notes": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": {
              "properties": { "status": { "const": "no-conversion" } },
              "required": ["status"]
            },
            "then": {
              "properties": {
                "calculatorMapping": {
                  "properties": {
                    "single": { "const": null },
                    "triple": { "const": null }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "status": { "const": "convertible" },
                "convention": {
                  "properties": { "axis": { "type": "null" } },
                  "required": ["axis"]
                }
              },
              "required": ["status", "convention"]
            },
            "then": {
              "properties": {
                "confidence": { "const": "low" },
                "calculatorMapping": {
                  "properties": { "triple": { "const": "physical-geometry" } }
                }
              }
            }
          }
        ]
      }
    }
  }
}
